# ─────────────────────────────────────────────────────────────────────────────
# AI Support Intelligence Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NOTE: The dashboard (KPIs, charts, filters, PDF export) works without any
# API key. Only the "Ask AI" chat feature requires LLM_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# LLM API key — required only for the "Ask AI" chatbot feature
# Compatible with OpenAI-format APIs (GPT-4o-mini)
LLM_API_KEY=your_llm_api_key_here

# Optional: override the default LLM base URL
# LLM_BASE_URL=https://your-llm-provider.com
